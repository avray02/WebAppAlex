rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function hasAppAccess(appId) {
      return signedIn()
        && (
          isAdmin()
          || appId in get(
            /databases/$(database)/documents/users/$(request.auth.uid)
          ).data.allowedApps
        );
    }

    function ownsExisting() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function ownsIncoming() {
      return signedIn() && request.resource.data.ownerUid == request.auth.uid;
    }

    function validStandardRanking(ranking) {
      return ranking is map
        && ranking.keys().hasOnly(['rank', 'participantCount'])
        && (
          !('rank' in ranking)
          || (ranking.rank is int && ranking.rank > 0)
        )
        && (
          !('participantCount' in ranking)
          || (
            ranking.participantCount is int
            && ranking.participantCount > 0
            && 'rank' in ranking
          )
        )
        && (
          !('rank' in ranking)
          || !('participantCount' in ranking)
          || ranking.participantCount >= ranking.rank
        );
    }

    function validStatusRanking(ranking, sentinel) {
      return ranking is map
        && ranking.keys().hasOnly(['rank'])
        && ranking.rank == sentinel;
    }

    function validRankings(data) {
      return data.rankings is map
        && data.rankings.keys().hasOnly(['overall', 'sex', 'category'])
        && data.rankings.keys().hasAll(['overall', 'sex', 'category'])
        && (
          (
            data.resultStatus == 'ranked'
            && validStandardRanking(data.rankings.overall)
            && validStandardRanking(data.rankings.sex)
            && validStandardRanking(data.rankings.category)
            && !('statusComment' in data)
          )
          || (
            data.resultStatus == 'dnf'
            && validStatusRanking(data.rankings.overall, -1)
            && validStatusRanking(data.rankings.sex, -1)
            && validStatusRanking(data.rankings.category, -1)
          )
          || (
            data.resultStatus == 'dsq'
            && validStatusRanking(data.rankings.overall, -2)
            && validStatusRanking(data.rankings.sex, -2)
            && validStatusRanking(data.rankings.category, -2)
          )
          || (
            data.resultStatus == 'dns'
            && validStatusRanking(data.rankings.overall, -3)
            && validStatusRanking(data.rankings.sex, -3)
            && validStatusRanking(data.rankings.category, -3)
          )
        )
        && (
          !('statusComment' in data)
          || (
            data.resultStatus != 'ranked'
            && data.statusComment is string
            && data.statusComment.size() <= 1000
          )
        );
    }

    function validCalendarDate(date) {
      return date is map
        && date.keys().hasOnly(['year', 'month', 'day'])
        && date.keys().hasAll(['year', 'month', 'day'])
        && date.year is int
        && date.year >= 1900
        && date.year <= 2100
        && date.month is int
        && date.month >= 1
        && date.month <= 12
        && date.day is int
        && date.day >= 1
        && date.day <= 31;
    }

    function dateKey(date) {
      return date.year * 10000 + date.month * 100 + date.day;
    }

    function validActivityDateRange(date) {
      return date is map
        && date.keys().hasOnly(['start', 'end'])
        && date.keys().hasAll(['start'])
        && validCalendarDate(date.start)
        && (
          !('end' in date)
          || (
            validCalendarDate(date.end)
            && dateKey(date.end) >= dateKey(date.start)
          )
        );
    }

    function validDistanceElevationData(data) {
      return data.distanceMeters is int
        && data.distanceMeters > 0
        && data.elevationGainMeters is int
        && data.elevationGainMeters >= 0;
    }

    function validRunningCompetitionData(data) {
      return data is map
        && data.keys().hasOnly([
          'distanceMeters',
          'elevationGainMeters',
          'durationSeconds',
          'resultStatus',
          'rankings',
          'statusComment'
        ])
        && data.keys().hasAll([
          'distanceMeters',
          'elevationGainMeters',
          'durationSeconds',
          'resultStatus',
          'rankings'
        ])
        && validDistanceElevationData(data)
        && data.durationSeconds is int
        && data.durationSeconds > 0
        && validRankings(data);
    }

    function validRunningCharityData(data) {
      return data is map
        && data.keys().hasOnly([
          'distanceMeters',
          'elevationGainMeters',
          'durationSeconds'
        ])
        && data.keys().hasAll([
          'distanceMeters',
          'elevationGainMeters'
        ])
        && validDistanceElevationData(data)
        && (
          !('durationSeconds' in data)
          || (
            data.durationSeconds is int
            && data.durationSeconds > 0
          )
        );
    }

    function validRoadCyclingCompetitionData(data) {
      return data is map
        && data.keys().hasOnly([
          'distanceMeters',
          'elevationGainMeters',
          'eventFormat',
          'stageCount',
          'durationSeconds',
          'averagePowerWatts',
          'resultStatus',
          'rankings',
          'statusComment'
        ])
        && data.keys().hasAll([
          'distanceMeters',
          'elevationGainMeters',
          'eventFormat',
          'durationSeconds',
          'resultStatus',
          'rankings'
        ])
        && validDistanceElevationData(data)
        && data.durationSeconds is int
        && data.durationSeconds > 0
        && (
          (
            data.eventFormat == 'single'
            && !('stageCount' in data)
          )
          || (
            data.eventFormat == 'stage-race'
            && data.stageCount is int
            && data.stageCount >= 2
            && data.stageCount <= 50
          )
        )
        && (
          !('averagePowerWatts' in data)
          || (
            data.averagePowerWatts is int
            && data.averagePowerWatts > 0
          )
        )
        && validRankings(data);
    }

    function validStageData(data) {
      return data is map
        && data.keys().hasOnly([
          'distanceMeters',
          'elevationGainMeters',
          'durationSeconds',
          'averagePowerWatts',
          'resultStatus',
          'rankings',
          'statusComment'
        ])
        && data.keys().hasAll([
          'distanceMeters',
          'elevationGainMeters',
          'durationSeconds',
          'resultStatus',
          'rankings'
        ])
        && validDistanceElevationData(data)
        && data.durationSeconds is int
        && data.durationSeconds > 0
        && (
          !('averagePowerWatts' in data)
          || (
            data.averagePowerWatts is int
            && data.averagePowerWatts > 0
          )
        )
        && validRankings(data);
    }

    function validTrack(track) {
      return track is map
        && track.keys().hasOnly([
          'fileName',
          'originalPointCount',
          'points'
        ])
        && track.keys().hasAll([
          'fileName',
          'originalPointCount',
          'points'
        ])
        && track.fileName is string
        && track.fileName.size() > 0
        && track.fileName.size() <= 200
        && track.originalPointCount is int
        && track.points is list
        && track.originalPointCount >= track.points.size()
        && track.points.size() >= 2
        && track.points.size() <= 500;
    }

    function validPerformanceStage(performanceId, stageId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'performanceId',
          'ownerUid',
          'order',
          'title',
          'date',
          'data',
          'track',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'id',
          'performanceId',
          'ownerUid',
          'order',
          'title',
          'date',
          'data',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id == stageId
        && request.resource.data.performanceId == performanceId
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.order is int
        && request.resource.data.order >= 0
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 2
        && request.resource.data.title.size() <= 120
        && validCalendarDate(request.resource.data.date)
        && validStageData(request.resource.data.data)
        && (
          !('track' in request.resource.data)
          || validTrack(request.resource.data.track)
        );
    }

    function validStageParent(performanceId) {
      let parent = getAfter(
        /databases/$(database)/documents/performances/$(performanceId)
      ).data;
      let stageDateKey = dateKey(request.resource.data.date);
      return parent.ownerUid == request.auth.uid
        && parent.activityDefinitionId == 'road-cycling__competition'
        && parent.data.eventFormat == 'stage-race'
        && request.resource.data.order < parent.data.stageCount
        && stageDateKey >= dateKey(parent.date.start)
        && (
          (
            'end' in parent.date
            && stageDateKey <= dateKey(parent.date.end)
          )
          || (
            !('end' in parent.date)
            && stageDateKey <= dateKey(parent.date.start)
          )
        );
    }

    function validActivityData() {
      let data = request.resource.data.data;
      return (
          request.resource.data.activityDefinitionId
            == 'running__competition'
          && request.resource.data.schemaVersion == 2
          && request.resource.data.sportKey == 'running'
          && request.resource.data.activityTypeKey == 'competition'
          && validRunningCompetitionData(data)
        )
        || (
          request.resource.data.activityDefinitionId == 'running__charity'
          && request.resource.data.schemaVersion == 1
          && request.resource.data.sportKey == 'running'
          && request.resource.data.activityTypeKey == 'charity'
          && validRunningCharityData(data)
        )
        || (
          request.resource.data.activityDefinitionId
            == 'road-cycling__competition'
          && request.resource.data.schemaVersion == 1
          && request.resource.data.sportKey == 'road-cycling'
          && request.resource.data.activityTypeKey == 'competition'
          && validRoadCyclingCompetitionData(data)
        );
    }

    function validPerformance(performanceId) {
      return request.resource.data.keys().hasOnly([
          'id',
          'ownerUid',
          'activityDefinitionId',
          'schemaVersion',
          'title',
          'sportKey',
          'activityTypeKey',
          'status',
          'date',
          'data',
          'notes',
          'tags',
          'searchKeywords',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'id',
          'ownerUid',
          'activityDefinitionId',
          'schemaVersion',
          'title',
          'sportKey',
          'activityTypeKey',
          'status',
          'date',
          'data',
          'tags',
          'searchKeywords',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id == performanceId
        && request.resource.data.status == 'completed'
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 2
        && request.resource.data.title.size() <= 120
        && validActivityDateRange(request.resource.data.date)
        && request.resource.data.tags is list
        && request.resource.data.searchKeywords is list
        && (
          !('notes' in request.resource.data)
          || (
            request.resource.data.notes is string
            && request.resource.data.notes.size() <= 1500
          )
        )
        && validActivityData();
    }

    function isValidInitialProfile(uid) {
      return signedIn()
        && uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'email',
          'displayName',
          'allowedApps',
          'createdAt'
        ])
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.displayName is string
        && request.resource.data.allowedApps is list
        && request.resource.data.allowedApps.size() == 0
        && request.resource.data.createdAt == request.time;
    }

    match /admins/{uid} {
      allow get: if signedIn() && uid == request.auth.uid;
      allow list, create, update, delete: if false;
    }

    match /users/{uid} {
      allow get: if signedIn() && (uid == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      allow create: if isAdmin() || isValidInitialProfile(uid);
      allow update, delete: if isAdmin();
    }

    match /performances/{performanceId} {
      allow read, delete:
        if hasAppAccess('athletic-performance') && ownsExisting();
      allow create:
        if hasAppAccess('athletic-performance')
        && ownsIncoming()
        && validPerformance(performanceId);
      allow update:
        if hasAppAccess('athletic-performance')
        && ownsExisting()
        && ownsIncoming()
        && request.resource.data.ownerUid == resource.data.ownerUid
        && validPerformance(performanceId);
    }

    match /performances/{performanceId}/stages/{stageId} {
      allow read, delete:
        if hasAppAccess('athletic-performance') && ownsExisting();
      allow create, update:
        if hasAppAccess('athletic-performance')
        && ownsIncoming()
        && validPerformanceStage(performanceId, stageId)
        && validStageParent(performanceId);
    }

    match /activityDefinitions/{definitionId} {
      allow read: if hasAppAccess('athletic-performance');
      allow create, update, delete: if isAdmin();
    }

  }
}
